<Window x:Class="Atletika_SutaznyPlan_Generator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Atletika_SutaznyPlan_Generator.ViewModels"
        Title="AkroBatika Printer"
        Width="1300" Height="850"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <!-- Outer frame (now square, no clipping) -->
    <Border CornerRadius="0"
            Background="White"
            BorderBrush="Black"
            BorderThickness="0"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.Resources>
                <!-- Reusable card template: image + bottom label -->
                <DataTemplate x:Key="ExerciseCardTemplate">
                    <Border CornerRadius="6"
                            BorderBrush="Black"
                            BorderThickness="1"
                            Margin="18"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <!-- Image area -->
                            <Border Grid.Row="0" Background="#EEEEEE">
                                <Image Source="{Binding Image}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <!-- Bottom label strip -->
                            <Border Grid.Row="1"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="0,1,0,0">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>

                <!-- Soft, rounded separators (used for all dividers) -->
                <Style x:Key="SoftSeparatorStyle" TargetType="Border">
                    <Setter Property="Background" Value="#B5B5B5"/>
                    <Setter Property="CornerRadius" Value="0"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Opacity" Value="0.95"/>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <!-- menu -->
                <RowDefinition Height="175"/>
                <!-- top controls -->
                <RowDefinition Height="Auto"/>
                <!-- thick separator (now uniform) -->
                <RowDefinition Height="*"/>
                <!-- main area -->
                <RowDefinition Height="44"/>
                <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ===================== Menu ===================== -->
            <Menu Grid.Row="0" Background="#F2F2F2" BorderBrush="#C8C8C8" BorderThickness="0,1,0,1">
                <MenuItem Header="Súbor">
                    <MenuItem Header="Načítať predchádzajúci tím" Command="{Binding LoadPreviousTeamCommand}"/>
                    <Separator/>
                    <MenuItem Header="Koniec" Command="{Binding ExitCommand}"/>
                </MenuItem>
            </Menu>

            <!-- ===================== Top controls ===================== -->
            <Grid Grid.Row="1" Margin="14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left block: Category + Discipline -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <TextBlock Text="Kategória" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox Width="220" Height="30"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          VerticalAlignment="Center"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1"
                              Header="Disciplína"
                              Margin="0,4,0,0"
                              BorderBrush="#8B5CF6"
                              BorderThickness="2"
                              Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <RadioButton Content="Combi"  Margin="0,6,0,0" IsChecked="{Binding IsCombi}"/>
                                <RadioButton Content="Tempo"  Margin="0,6,0,0" IsChecked="{Binding IsTempo}"/>
                                <RadioButton Content="Balans" Margin="0,6,0,0" IsChecked="{Binding IsBalans}"/>
                            </StackPanel>

                            <!-- Separator (soft + rounded) -->
                            <Border Grid.Column="1"
                                    Width="4"
                                    Margin="3,2"
                                    Style="{StaticResource SoftSeparatorStyle}"/>

                            <StackPanel Grid.Column="2">
                                <RadioButton Content="WP"  Margin="0,6,0,0" IsChecked="{Binding IsWP}"/>
                                <RadioButton Content="MP"  Margin="0,6,0,0" IsChecked="{Binding IsMP}"/>
                                <RadioButton Content="MxP" Margin="0,6,0,0" IsChecked="{Binding IsMxP}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <RadioButton Content="WG" Margin="0,6,0,0" IsChecked="{Binding IsWG}"/>
                                <RadioButton Content="MG" Margin="0,6,0,0" IsChecked="{Binding IsMG}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>

                <!-- Right block: 4 athlete cards -->
                <Grid Grid.Column="1" Margin="24,0,0,0">
                    <Grid.Resources>
                        <Style x:Key="PersonCardStyle" TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="BorderBrush" Value="#D6D6D6"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="#F7F7F7"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Margin" Value="10,0,0,0"/>
                        </Style>

                        <Style x:Key="NameBoxStyle" TargetType="TextBox">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="Margin" Value="0,6,0,8"/>
                            <Setter Property="Padding" Value="6,3"/>
                        </Style>

                        <Style x:Key="DateStyle" TargetType="DatePicker">
                            <Setter Property="Height" Value="28"/>
                        </Style>
                    </Grid.Resources>

                    <UniformGrid Columns="4" VerticalAlignment="Top">
                        <Border Style="{StaticResource PersonCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Top" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource NameBoxStyle}" Text="{Binding TopName, UpdateSourceTrigger=PropertyChanged}"/>
                                <DatePicker Style="{StaticResource DateStyle}" SelectedDate="{Binding TopBirth}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PersonCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Middle" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource NameBoxStyle}" Text="{Binding TopName, UpdateSourceTrigger=PropertyChanged}"/>
                                <DatePicker Style="{StaticResource DateStyle}" SelectedDate="{Binding TopBirth}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PersonCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Middle" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource NameBoxStyle}" Text="{Binding TopName, UpdateSourceTrigger=PropertyChanged}"/>
                                <DatePicker Style="{StaticResource DateStyle}" SelectedDate="{Binding TopBirth}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PersonCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Base" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource NameBoxStyle}" Text="{Binding TopName, UpdateSourceTrigger=PropertyChanged}"/>
                                <DatePicker Style="{StaticResource DateStyle}" SelectedDate="{Binding TopBirth}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Grid>

            <!-- ===================== Thick horizontal divider (soft + uniform) ===================== -->
            <Border Grid.Row="2"
                Height="4"
                HorizontalAlignment="Stretch"
                Margin="0"
                Style="{StaticResource SoftSeparatorStyle}"/>   

            <!-- ===================== Main split panels ===================== -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- divider now auto -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Individuálne cvičebné tvary"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding IndividualExercises}"
                                      ItemTemplate="{StaticResource ExerciseCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                            Content="Vybrať"
                            Width="92" Height="38"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="Black"
                            BorderThickness="2"
                            Background="White"
                            Command="{Binding ChooseIndividualCommand}"/>
                </Grid>

                <!-- Vertical divider (soft + uniform) -->
                <Border Grid.Column="1"
                    Width="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Margin="0"
                    Style="{StaticResource SoftSeparatorStyle}"/>

                <!-- Right panel -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Skupinové cvičebné tvary"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupExercises}"
                                      ItemTemplate="{StaticResource ExerciseCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                            Content="Vybrať"
                            Width="92" Height="38"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="Black"
                            BorderThickness="2"
                            Background="White"
                            Command="{Binding ChooseGroupCommand}"/>
                </Grid>
            </Grid>

            <!-- ===================== Footer (soft top separator, uniform thickness) ===================== -->
            <Border Grid.Row="4" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Height="4"
                        HorizontalAlignment="Stretch"
                        Margin="0"
                        Style="{StaticResource SoftSeparatorStyle}"/>

                    <Grid Grid.Row="1" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                           Text="{Binding TrainerName, StringFormat=Tréner: {0}}"
                           FontSize="22"
                           VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                           Text="{Binding ClubName, StringFormat=   |   NázovKlubu: {0}}"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0"/>

                        <TextBlock Grid.Column="3"
                           Text="{Binding EventName, StringFormat=Podujatie: {0}}"
                           FontSize="22"
                           VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>